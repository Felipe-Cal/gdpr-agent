# ─────────────────────────────────────────────────────────────────────────────
# GDPR Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# All settings have sensible defaults except GCP_PROJECT_ID.
# ─────────────────────────────────────────────────────────────────────────────

# ── GCP core ──────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id

# europe-west4 = Netherlands — keeps all data inside the EU (GDPR Article 44)
GCP_REGION=europe-west4

# Gemini LLM endpoint region — europe-west1 has wider model availability
LLM_REGION=europe-west1

# ── BigQuery vector store ──────────────────────────────────────────────────────
# Created by: python -m setup.create_dataset
BQ_DATASET=gdpr_agent
BQ_TABLE=document_chunks

# ── Models ────────────────────────────────────────────────────────────────────
# Gemini 2.0 Flash Lite: cheapest current Gemini, sufficient for legal Q&A
GEMINI_MODEL=gemini-2.0-flash-lite
EMBEDDING_MODEL=text-embedding-004

# ── RAG retrieval ─────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=6

# ── Phase 3: Observability — LangSmith ────────────────────────────────────────
# EU endpoint ensures query data stays in Europe
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=gdpr-agent

# ── Phase 3: Observability — LangFuse ────────────────────────────────────────
# Self-hostable alternative — keeps traces inside your GCP perimeter (GDPR-safe)
LANGFUSE_TRACING=false
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://eu.cloud.langfuse.com

# ── Phase 3: Evaluation ───────────────────────────────────────────────────────
EVAL_MODEL=gemini-2.0-flash-lite

# ── Phase 4: Self-hosted serving (vLLM on GKE) ───────────────────────────────
# Set VLLM_ENDPOINT to the GKE LoadBalancer IP after deployment:
#   kubectl get svc vllm-mistral -n gdpr-serving
VLLM_ENDPOINT=http://localhost:8000
VLLM_MODEL=mistral-7b
GKE_CLUSTER_NAME=gdpr-serving
GKE_ZONE=europe-west4-b

# ── Phase 5: Fine-tuning ──────────────────────────────────────────────────────
# Base model for local training (train_local.py) — no HF auth required
FINETUNE_BASE_MODEL=Qwen/Qwen2.5-0.5B-Instruct
# GCS bucket for Vertex AI training artifacts (vertex_job.py / tpu_job.py)
FINETUNE_GCS_BUCKET=your-gcs-bucket-name

# ── Phase 6: Production MLOps ────────────────────────────────────────────────
# GCS path where Vertex AI Pipelines stores run artifacts
PIPELINE_ROOT=gs://your-gcs-bucket/pipeline-runs
# KMS key resource name (set after running: python -m phase6.kms setup)
# Format: projects/PROJECT/locations/REGION/keyRings/RING/cryptoKeys/KEY
CMEK_KEY_NAME=
# Quality gate thresholds — pipeline halts if eval scores fall below these
MIN_GROUNDEDNESS=3.5
MIN_COHERENCE=3.5
# Fine-tuning trigger — only trigger fine-tuning if scores drop this low
FINETUNE_TRIGGER_THRESHOLD=3.0
