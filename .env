# GCP Project settings
GCP_PROJECT_ID=gdpr-agent-project
GCP_REGION=europe-west4   # BigQuery + embeddings — data stays in NL
LLM_REGION=europe-west4

# BigQuery vector store
BQ_DATASET=gdpr_agent
BQ_TABLE=document_chunks

# Model config (defaults are fine to start)
GEMINI_MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=text-embedding-004
