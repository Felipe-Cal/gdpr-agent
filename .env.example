# GCP Project settings
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west4

# BigQuery vector store — dataset and table are created by setup/create_dataset.py
BQ_DATASET=gdpr_agent
BQ_TABLE=document_chunks

# Model config (defaults are fine to start)
GEMINI_MODEL=gemini-1.5-pro
EMBEDDING_MODEL=text-embedding-004

# Phase 3 — Observability: LangSmith
# EU endpoint ensures query data stays in Europe
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=gdpr-agent

# Phase 3 — Observability: LangFuse
# Self-hostable alternative — keeps traces inside your GCP perimeter (more GDPR-safe)
# In Phase 6 we deploy LangFuse on Cloud Run; update LANGFUSE_HOST to that URL.
LANGFUSE_TRACING=false
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://eu.cloud.langfuse.com

# Phase 3 — Evaluation
# gemini-2.0-flash-lite is sufficient as LLM judge and cheapest available
EVAL_MODEL=gemini-2.0-flash-lite
